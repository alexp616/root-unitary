{
  "name": "root-unitary dev",
  "image": "sagemath/sage:latest",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-vscode.cpptools",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y build-essential pkg-config libflint-dev cython3 && apt-get clean && rm -rf /var/lib/apt/lists/*",
  "mounts": [
    "type=volume,target=/var/lib/sage"
  ],
  "containerEnv": {
    "SAGE_NUM_THREADS": "4"
  }
}
